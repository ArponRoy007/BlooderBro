<%- include("../partials/header", { title: "Admin Access", css: "login.css" }) %>
<main style="height: 80vh; display: flex; align-items: center; justify-content: center; background: #0f172a;">
    <div style="background: #1e293b; padding: 40px; border-radius: 15px; box-shadow: 0 10px 30px rgba(230,57,70,0.2); width: 100%; max-width: 400px; border: 1px solid #334155; text-align: center;">
        <img src="/images/logo.png" style="width: 60px; border-radius: 50%; margin-bottom: 20px;">
        <h2 style="color: white; margin-bottom: 20px;">Official Command Center</h2>
        <form action="/admin/login" method="POST">
            <input type="email" name="email" placeholder="Official Email" required style="width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 5px; border: none; background: #0f172a; color: white;">
            <input type="password" name="password" placeholder="Passcode" required style="width: 100%; padding: 12px; margin-bottom: 20px; border-radius: 5px; border: none; background: #0f172a; color: white;">
            <button type="submit" style="width: 100%; padding: 12px; background: #e63946; color: white; border: none; border-radius: 5px; font-weight: bold; cursor: pointer; font-size: 1.1rem;">Access Dashboard</button>
        </form>
    </div>
</main>