<%- include("partials/header", { title: "BlooderBro - Home" , css: "index.css" }) %>

    <nav>
        <div class="nav-left">
            <a href="/" style="text-decoration: none; display: flex; align-items: center; gap: 12px;">
                <img src="/images/logo2.png" alt="Logo"
                    style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover;"
                    onerror="this.style.display='none'" />
                <div class="nav-title" style="margin: 0; font-weight: bold; font-size: 1.5rem; color:#fdfdfd">BlooderBro
                </div>
            </a>
        </div>

        <button class="hamburger" onclick="document.getElementById('nav-links').classList.toggle('active')">☰</button>

        <div class="nav-right" id="nav-links">
            <% if (locals.currentUser) { %>
                <a href="/profile"><button class="btn">Profile</button></a>
                <a href="/logout"><button class="btn">Logout</button></a>
            <% } else { %>
                <a href="/login"><button class="btn">Login</button></a>
                <a href="/register"><button class="btn">Sign Up</button></a>
            <% } %>
        </div>
    </nav>

    <section class="hero">
        <div class="container hero-content">
            <h1>Donate Blood. Save Lives.</h1>
            <p>Join our mission to save lives across the nation.</p>
            <a href="<%= locals.currentUser ? '/request' : '/register' %>" class="btnn btn-primary">
                <%= locals.currentUser ? "Request Blood" : "Join as a Donor" %>
            </a>
        </div>
    </section>

    <section class="top-users">
        <div class="container">
            <h2 class="text-center" style="margin-bottom: 40px; color: #333;">Our Community Heroes</h2>
            <div class="top-users-container">

                <% if (topDonor) { %>
                    <div class="user-card donor" style="position: relative;">
                        <div
                            style="position: absolute; top: -15px; right: -15px; background: #e63946; color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; box-shadow: 0 4px 10px rgba(230,57,70,0.4);">
                            🏆</div>
                        <div class="user-avatar"><i class="fas fa-heart text-danger"></i></div>
                        <h3 class="user-name text-center">
                            <%= topDonor.name %>
                        </h3>
                        <div class="user-details text-center">
                            <span style="display:block; font-size: 0.85rem; color: #666; font-weight: 600;">Top
                                Lifesaver</span>
                            <div class="blood-group">
                                <%= topDonor.bloodGroup %>
                            </div>
                            <div class="donation-count" style="color: #e63946; font-weight: bold;">
                                <%= topDonor.donationsCount %> Donations!
                            </div>
                        </div>
                    </div>
                <% } %>

                <% if (topNeeder) { %>
                    <div class="user-card needer">
                        <div class="user-avatar"><i class="fas fa-hand-holding-medical"></i></div>
                        <h3 class="user-name text-center">
                            <%= topNeeder.name %>
                        </h3>
                        <div class="user-details text-center">
                            <span style="display:block; font-size: 0.85rem; color: #666; font-weight: 600;">Top
                                Requester</span>
                            <div class="blood-group">
                                <%= topNeeder.bloodGroup %>
                            </div>
                            <div class="donation-count">
                                <%= topNeeder.requestsCount %> Requests
                            </div>
                        </div>
                    </div>
                <% } %>

                <% if (!topDonor && !topNeeder) { %>
                    <p class="text-center" style="color: #666; width: 100%;">Our heroes are getting
                        ready. Will you be the first?</p>
                <% } %>
            </div>
        </div>
    </section>

    <section class="reviews">
        <div class="container">
            <h2 class="text-center" style="margin-bottom: 30px;">What our users say</h2>

            <div class="top-review-card text-center"
                style="max-width: 750px; margin: 0 auto; padding: 40px; background: linear-gradient(135deg, #ffffff, #fdfdfd); border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.06); border: 1px solid #f1f1f1; position: relative;">
                <i class="fas fa-quote-left"
                    style="font-size: 4rem; color: #e63946; opacity: 0.1; position: absolute; top: 20px; left: 30px;"></i>

                <% if (reviews && reviews.length > 0) { %>
                    <div class="stars" style="color: #ffc107; font-size: 1.5rem; margin-bottom: 15px;">
                        <% for(let i=0; i<reviews[0].rating; i++) { %><i class="fas fa-star"></i><% } %>
                        <% for(let i=0; i<(5-reviews[0].rating); i++) { %><i class="far fa-star"></i><% } %>
                    </div>
                    <p class="review-text"
                        style="font-size: 1.3rem; font-style: italic; color: #444; margin-bottom: 20px; line-height: 1.8;">
                        "<%= reviews[0].text %>"</p>
                    <h4 style="color: #e63946; font-weight: 600; font-size: 1.1rem;">- <%= reviews[0].userName %>
                    </h4>
                <% } else { %>
                    <p style="font-size: 1.2rem; color: #666;">No reviews yet. Be the first to share your experience!</p>
                <% } %>

                <button onclick="openReviewModal()" class="btnn btn-primary"
                    style="margin-top: 30px; padding: 10px 25px; font-size: 1rem;">View All Reviews & Add Yours</button>
            </div>
        </div>
    </section>

    <div id="reviewModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeReviewModal()">&times;</span>
            <h2 style="text-align: center; margin-bottom: 20px; color: #333;">Community Reviews</h2>

            <div style="max-height: 400px; overflow-y: auto; padding-right: 10px;">
                <% if (reviews && reviews.length > 0) { %>
                    <% reviews.forEach(review => { %>
                        <div style="background: #f8f9fa; padding: 20px; border-radius: 10px; margin-bottom: 15px; position: relative; border-left: 4px solid #e63946;">

                            <% if (locals.currentUser && review.userId.toString() === locals.currentUser.id) { %>
                                <form action="/review/delete/<%= review._id %>" method="POST"
                                    style="position: absolute; top: 15px; right: 15px;">
                                    <button type="submit"
                                        style="background: none; border: none; color: #999; cursor: pointer; font-size: 1.1rem; transition: 0.3s;"
                                        onmouseover="this.style.color='#e63946'" onmouseout="this.style.color='#999'"><i class="fas fa-trash"></i></button>
                                </form>
                            <% } %>

                            <h4 style="margin-bottom: 5px; color: #333;"><%= review.userName %></h4>
                            <div class="stars" style="color: #ffc107; margin-bottom: 10px; font-size: 0.9rem;">
                                <% for(let i=0; i<review.rating; i++) { %><i class="fas fa-star"></i><% } %>
                                <% for(let i=0; i<(5-review.rating); i++) { %><i class="far fa-star"></i><% } %>
                            </div>
                            <p style="color: #555; font-style: italic; font-size: 0.95rem;">"<%= review.text %>"</p>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p class="text-center" style="color: #888;">No reviews available to show.</p>
                <% } %>
            </div>

            <% if (locals.currentUser) { %>
                <div style="margin-top: 25px; border-top: 2px solid #eee; padding-top: 20px;">
                    <h4 style="margin-bottom: 15px; color: #333;">Leave a Review</h4>
                    <form action="/review" method="POST">
                        <select name="rating" required
                            style="width: 100%; padding: 12px; margin-bottom: 15px; border-radius: 6px; border: 1px solid #ddd; outline: none;">
                            <option value="5">⭐⭐⭐⭐⭐ (5/5)</option>
                            <option value="4">⭐⭐⭐⭐ (4/5)</option>
                            <option value="3">⭐⭐⭐ (3/5)</option>
                            <option value="2">⭐⭐ (2/5)</option>
                            <option value="1">⭐ (1/5)</option>
                        </select>
                        <textarea name="text" required placeholder="Share your experience..."
                            style="width: 100%; padding: 12px; border-radius: 6px; border: 1px solid #ddd; margin-bottom: 15px; min-height: 80px; resize: vertical; outline: none;"></textarea>
                        <button type="submit" class="btnn btn-primary"
                            style="width: 100%; text-align: center; border-radius: 6px;">Post My Review</button>
                    </form>
                </div>
            <% } else { %>
                <p style="text-align: center; margin-top: 25px; padding-top: 20px; border-top: 2px solid #eee; color: #666; font-size: 0.95rem;">
                    Please <a href="/login" style="color: #e63946; font-weight: bold;">log in</a> to leave a review.
                </p>
            <% } %>
        </div>
    </div>

    <script>
        const reviewModal = document.getElementById("reviewModal");

        function openReviewModal() {
            reviewModal.style.display = "block";
            document.body.style.overflow = "hidden"; // Prevents background from scrolling
        }

        function closeReviewModal() {
            reviewModal.style.display = "none";
            document.body.style.overflow = "auto";
        }

        // Close modal if user clicks outside the white box
        window.onclick = function (event) {
            if (event.target == reviewModal) {
                closeReviewModal();
            }
        }

        // 🛡️ THE CACHE-BUSTER: Fixes the A/B Glitch!
        window.addEventListener('pageshow', function(event) {
            // If the browser loaded this page from memory (cache), force a fresh reload!
            if (event.persisted) {
                window.location.reload();
            }
        });
    </script>

<%- include("partials/footer") %>