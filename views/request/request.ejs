<%- include("../partials/header", { title: "Request Blood" , css: "request.css" }) %>

  <nav>
    <div class="nav-left">
      <a href="/" style="text-decoration: none; display: flex; align-items: center; gap: 12px;">
        <img src="/images/logo2.png" alt="Logo" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover;"
          onerror="this.style.display='none'" />
        <div class="nav-title" style="margin: 0; font-weight: bold; font-size: 1.5rem; color: #fdfdfd;">BlooderBro</div>
      </a>
    </div>

    <button class="hamburger" onclick="document.getElementById('nav-links').classList.toggle('active')">☰</button>

    <div class="nav-right" id="nav-links">
      <% if (typeof currentUser !=='undefined' && currentUser) { %>
        <a href="/"><button class="btn">Home</button></a>
        <a href="/profile"><button class="btn">Profile</button></a>
        <a href="/logout"><button class="btn">Logout</button></a>
        <% } else { %>
          <a href="/login"><button class="btn">Login</button></a>
          <a href="/register"><button class="btn">Sign Up</button></a>
          <% } %>
    </div>
  </nav>

  <main>
    <div class="container" style="margin: 0 auto;">
      <h1 class="page-title">Request Blood in Just a Few Steps</h1>

      <p class="emergency-note">For immediate emergencies, please also call our emergency hotline at
        <strong>1800-BLOOD-HELP</strong>
      </p>

      <div class="form-card" style="margin: 0 auto;">
        <h2 class="form-title">Blood Request Form</h2>

        <form method="POST" action="/request">

          <div class="form-group">
            <label for="fullName" class="required">Full Name</label>
            <input type="text" id="fullName" name="fullName" placeholder="Enter patient or requestor name" required>
          </div>

          <div class="form-group">
            <label class="required">WhatsApp Number</label>
            <div style="display: flex; gap: 10px; margin-bottom: 5px;">
              <select name="countryCode" required style="width: 40%; padding: 10px; border-radius: 5px; border: 1px solid #ccc; background-color: white;">
                <option value="91">🇮🇳 India (+91)</option>
                <option value="880">🇧🇩 Bangladesh (+880)</option>
                <option value="977">🇳🇵 Nepal (+977)</option>
                <option value="1">🇺🇸 USA (+1)</option>
                <option value="1">🇨🇦 Canada (+1)</option>
                <option value="61">🇦🇺 Australia (+61)</option>
              </select>
              <input type="tel" id="phone" name="phone" placeholder="Enter number without code" required style="width: 60%; padding: 10px; border-radius: 5px; border: 1px solid #ccc;">
            </div>
            <div class="helper-text">Donors will contact you directly on WhatsApp to help.</div>
          </div>

          <div class="form-group">
            <label for="socialLink">Social Media Backup (Optional)</label>
            <input type="url" id="socialLink" name="socialLink" placeholder="Facebook or Instagram Profile Link" style="width: 100%; padding: 10px; border-radius: 5px; border: 1px solid #ccc;">
            <div class="helper-text">In case WhatsApp is unreachable.</div>
          </div>

          <div class="form-group">
            <label for="email" class="required">Email Address</label>
            <input type="email" id="email" name="email" placeholder="Enter your email address" required>
          </div>

          <div class="form-group">
            <label for="bloodGroup" class="required">Required Blood Group</label>
            <select id="bloodGroup" name="bloodGroup" required>
              <option value="" disabled selected>Select blood group</option>
              <option value="A+">A+</option>
              <option value="A-">A-</option>
              <option value="B+">B+</option>
              <option value="B-">B-</option>
              <option value="AB+">AB+</option>
              <option value="AB-">AB-</option>
              <option value="O+">O+</option>
              <option value="O-">O-</option>
            </select>
          </div>

          <div class="form-group">
            <label for="urgencyLevel" class="required">Urgency Level</label>
            <select id="urgencyLevel" name="urgencyLevel">
              <option value="" disabled selected>Select urgency level</option>
              <option value="emergency">Emergency</option>
              <option value="24hours">Within 24 hours</option>
              <option value="routine">Routine</option>
            </select>
          </div>

          <div class="form-group">
            <label for="hospitalName" class="required">Hospital Name</label>
            <input type="text" id="hospitalName" name="hospitalName" placeholder="Enter hospital name">
          </div>

          <div class="form-group">
            <label for="hospitalAddress" class="required">Hospital Address</label>
            <textarea id="hospitalAddress" name="hospitalAddress" placeholder="Enter complete hospital address"
              style="min-height: 80px;"></textarea>
          </div>

          <div class="form-group">
            <label for="pincode" class="required">Pincode/ZIP Code</label>
            <input type="number" id="pincode" name="pincode" placeholder="Enter hospital address pincode or ZIP code" required>
          </div>

          <div class="form-group">
            <label for="message">Additional Message</label>
            <textarea id="message" name="message"
              placeholder="Enter any additional details or special requirements (optional)"></textarea>
          </div>

          <button type="submit" class="submit-btn">Request Blood Now</button>
        </form>
      </div>
    </div>
  </main>

  <%- include("../partials/footer") %>